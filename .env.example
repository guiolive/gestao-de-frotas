# ═══════════════════════════════════════════════════
# Gestão de Frotas — Variáveis de Ambiente
# ═══════════════════════════════════════════════════
# Em dev: copie pra .env (gitignored) e preencha.
# Em prod: passe via secret manager / variáveis do orquestrador.
# NUNCA commitar `.env` real no git.

# ── Banco de dados (PostgreSQL) ──
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Em prod, exigir SSL: ?sslmode=require no fim
DATABASE_URL="postgresql://postgres:senha_segura@localhost:5432/gestao_frotas"

# ── Autenticação ──
# Segredo JWT — MÍNIMO 32 caracteres. Em prod, gere com:
#   openssl rand -base64 48
# Trocar este segredo invalida todas as sessões ativas.
JWT_SECRET="trocar_por_segredo_longo_de_pelo_menos_32_chars"

# ── Email (SMTP) ──
# Pra reset de senha + alertas de manutenção. Se vazio, esses fluxos
# falham silenciosamente em logs (não derrubam o app).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ── Alertas ──
# Email do gestor que recebe alertas de manutenção atrasada / OS na Prime
EMAIL_GESTOR_FROTA=""

# ── Aplicação ──
# URL base usada em emails (links de reset de senha). Em prod, deve ser
# o domínio público com https — sem barra no fim.
# Ex.: https://gestao-frota.dirad.ufg.br
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Ambiente ──
# `production` ativa CSP, HSTS efetivo, cookies secure-only, etc.
NODE_ENV="development"

# ── Logging ──
# Nível: debug | info | warn | error (default info). Em prod, prefira `info`.
LOG_LEVEL="info"
