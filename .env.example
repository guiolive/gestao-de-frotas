# ═══════════════════════════════════════════════════
# Gestão de Frotas — Variáveis de Ambiente
# ═══════════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores.

# ── Banco de dados (PostgreSQL) ──
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:senha_segura@localhost:5432/gestao_frotas"

# ── Autenticação ──
# Segredo JWT (mínimo 32 caracteres, gere com: openssl rand -base64 48)
JWT_SECRET="trocar_por_segredo_longo_de_pelo_menos_32_chars"

# ── Email (SMTP) ──
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ── Alertas ──
# Email do gestor que recebe alertas de manutenção atrasada
EMAIL_GESTOR_FROTA=""

# ── Aplicação ──
# URL base da aplicação (usado em emails de reset de senha)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Logging ──
# Nível de log: debug | info | warn | error (default: info)
LOG_LEVEL="info"
